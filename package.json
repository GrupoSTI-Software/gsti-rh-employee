{
  "name": "gsti-pwa-empleado",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "ssl": "ng serve --host 0.0.0.0 --ssl --ssl-key ssl/localhost-key.pem --ssl-cert ssl/localhost.pem",
    "prestart": "node scripts/load-env.js",
    "start": "concurrently --names \"DEV,LINT\" --prefix-colors \"cyan,yellow\" \"ng serve\" \"npm run lint:watch\"",
    "start:dev-only": "ng serve",
    "prebuild": "node scripts/load-env.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint . --ext .ts,.html",
    "lint:fix": "eslint . --ext .ts,.html --fix",
    "lint:watch": "chokidar 'src/**/*.ts' 'src/**/*.html' -c 'npm run lint' --initial --silent",
    "serve:ssr:gsti-pwa-empleado": "node dist/gsti-pwa-empleado/server/server.mjs",
    "prepare": "husky"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/localize": "^21.0.6",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.0.0",
    "@angular/ssr": "^21.0.4",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@passwordless-id/webauthn": "^2.3.4",
    "@primeng/themes": "^21.0.2",
    "@primeuix/themes": "^2.0.2",
    "express": "^5.1.0",
    "firebase": "^12.8.0",
    "face-api.js": "^0.22.2",
    "ngx-translate": "^0.0.1-security",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.2",
    "rxjs": "~7.8.0",
    "signature_pad": "^5.1.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/js": "^9.0.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "^21.0.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.8"
  }
}
