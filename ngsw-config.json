{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "navigationFallback": {
    "index": "/index.html",
    "blacklist": ["/api/**"]
  },
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    },
    {
      "name": "face-api-models",
      "installMode": "lazy",
      "updateMode": "lazy",
      "resources": {
        "files": [
          "/assets/face-api-models/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-attendance",
      "urls": ["/api/attendance/**", "/api/assist/**"],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "1m",
        "timeout": "10s",
        "strategy": "freshness"
      }
    }
  ]
}
